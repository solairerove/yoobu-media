# Shared with Java service (Railway project-level variable)
INTERNAL_API_KEY=your-secret-key-min-32-chars

# R2 (Cloudflare)
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=yoobu-media
R2_REGION=auto
CDN_BASE_URL=https://media.yoobu.app

# Optional (defaults shown)
PORT=3000
MAX_FILE_SIZE=2097152
MAX_IMAGE_DIMENSION=1200
WEBP_QUALITY=80

# Logging
RUST_LOG=image_service=info,tower_http=info
